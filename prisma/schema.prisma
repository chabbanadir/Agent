generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  companyDescription String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  gmailEmail         String?
  isSyncEnabled      Boolean             @default(true)
  gmailSettings      Json?
  whatsappNumber     String?
  whatsappSettings   Json?
  isSyncing          Boolean             @default(false)
  lastSyncAt         DateTime?
  escalationChannel  String?             @default("EMAIL")
  managerEmail       String?
  managerWhatsapp    String?
  aiModels           AIModel[]
  agents             Agent[]
  apiKeys            ApiKey[]
  channelAccounts    ChannelAccount[]
  documents          Document[]
  messages           Message[]
  simulations        Simulation[]
  users              User[]
  whatsappSessions   WhatsAppSession[]
  blacklistedNumbers BlacklistedNumber[]
  conversationFacts  ConversationFact[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  tenantId      String?
  accounts      Account[]
  sessions      Session[]
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agent {
  id                String         @id @default(cuid())
  tenantId          String
  name              String
  description       String?
  provider          String         @default("openai")
  model             String         @default("gpt-4o")
  systemPrompt      String?
  config            Json?
  persuasionLevel   Float          @default(0.5)
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  escalationChannel String?        @default("EMAIL")
  managerEmail      String?
  managerWhatsapp   String?
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  channels          AgentChannel[]

  @@index([tenantId])
}

model ChannelAccount {
  id                String             @id @default(cuid())
  tenantId          String
  type              String
  name              String?
  address           String
  credentials       Json?
  config            Json?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lastHistoryId     String?
  lastWatchAt       DateTime?
  agentChannels     AgentChannel[]
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages          Message[]          @relation("AccountMessages")
  conversationFacts ConversationFact[]

  @@unique([tenantId, address, type])
  @@index([tenantId])
}

model AgentChannel {
  id               String          @id @default(cuid())
  agentId          String
  channelAccountId String?
  channel          String
  systemPrompt     String?
  config           Json?
  isActive         Boolean         @default(true)
  agent            Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channelAccount   ChannelAccount? @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)

  @@unique([agentId, channelAccountId])
}

model Document {
  id         String                 @id @default(cuid())
  tenantId   String
  name       String
  content    String
  vector     Unsupported("vector")?
  status     String                 @default("UPLOADED")
  metadata   Json?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  mimeType   String?
  rawContent Bytes?
  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  chunks     DocumentChunk[]

  @@index([tenantId])
}

model DocumentChunk {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  vector     Unsupported("vector")?
  createdAt  DateTime               @default(now())
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model AIModel {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  provider  String
  modelType String
  config    Json?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Message {
  id               String          @id @default(cuid())
  tenantId         String
  channelAccountId String?
  externalId       String?         @unique
  threadId         String?
  source           String
  sender           String
  content          String
  role             String          @default("user")
  status           String          @default("RECEIVED")
  bookingStatus    String          @default("NONE")
  category         String?
  trace            Json?
  parentMessageId  String?
  createdAt        DateTime        @default(now())
  lastProcessedAt  DateTime?
  retryCount       Int             @default(0)
  rfcMessageId     String?
  draftContent     String?
  isEscalation     Boolean         @default(false)
  isGhostReply     Boolean         @default(false)
  senderName       String?
  channelAccount   ChannelAccount? @relation("AccountMessages", fields: [channelAccountId], references: [id], onDelete: Cascade)
  parentMessage    Message?        @relation("MessageThread", fields: [parentMessageId], references: [id])
  replies          Message[]       @relation("MessageThread")
  tenant           Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([sender])
  @@index([threadId])
  @@index([rfcMessageId])
}

model Simulation {
  id        String   @id @default(cuid())
  tenantId  String
  agentId   String?
  sender    String
  input     String
  output    String
  latency   Float?
  tokens    Json?
  trace     Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model ApiKey {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  key       String    @unique
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model WhatsAppSession {
  id        String   @id @default(cuid())
  tenantId  String
  address   String   @unique
  data      Json?
  status    String   @default("DISCONNECTED")
  qr        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BlacklistedNumber {
  id        String   @id @default(cuid())
  tenantId  String
  channel   String   @default("WHATSAPP")
  address   String
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, address])
  @@index([tenantId])
}

model ConversationFact {
  id               String   @id @default(cuid())
  tenantId         String
  channelAccountId String?
  senderUri        String
  factSummary      String
  createdAt        DateTime @default(now())

  channelAccount ChannelAccount? @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([senderUri])
}
